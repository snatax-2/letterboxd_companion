{
  "name": "ludex-rating-companion",
  "version": "1.0.0",
  "description": "Ludex Rating Companion — app de notation de films avec recherche TMDb, watchlist et providers de streaming (BE).",
  "private": true,
  "scripts": {
    "build": "node scripts/build-app-js.js && node scripts/generate-sw-cache.js",
    "build:js": "node scripts/build-app-js.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "test:e2e": "playwright test",
    "check:load": "node scripts/check-load.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "1.56.0",
    "jsdom": "^29.1.1"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0"
  }
}
